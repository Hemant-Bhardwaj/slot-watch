# Copy this to .env.local for local development
# None of these are required to run the app — they enable optional features

# Supabase (optional — for email notifications and subscriber storage)
# Get these from https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# These go in GitHub Actions secrets (not in .env)
# SUPABASE_SERVICE_KEY=your-service-role-key
# RESEND_API_KEY=your-resend-api-key
# VFS_EMAIL=your-vfs-account@email.com
# VFS_PASSWORD=your-vfs-password
# TLSC_EMAIL=your-tlscontact-account@email.com
# TLSC_PASSWORD=your-tlscontact-password
# BLS_EMAIL=your-bls-account@email.com
# BLS_PASSWORD=your-bls-password
